# ─── Supabase ─────────────────────────────────────────────────────────────────
# Project URL and anon/public key — both found in Supabase dashboard > Settings > API
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_KEY=eyJ...

# ─── Anthropic (Claude) ───────────────────────────────────────────────────────
# From https://console.anthropic.com/settings/keys
ANTHROPIC_KEY=sk-ant-...

# ─── France Travail API ────────────────────────────────────────────────────────
# Register at https://francetravail.io/produits-partages/catalogue to get credentials
FT_CLIENT_ID=your_client_id
FT_CLIENT_SECRET=your_client_secret
